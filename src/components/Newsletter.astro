---
const publicationId = 'pub_4d9502b6-ee55-4d47-9f32-4e3f50b3645a';
---

<aside class="newsletter" id="newsletter" aria-labelledby="newsletter-title">
  <div class="newsletter-header">
    <h3 id="newsletter-title">Get new notes by email</h3>
    <p>One thoughtful email when a new post goes live.</p>
  </div>

  <div class="beehiiv-embed" data-test-id="beehiiv-embed">
    <iframe
      title="Beehiiv newsletter signup"
      src={`https://subscribe-forms.beehiiv.com/${publicationId}`}
      data-test-id="beehiiv-iframe"
      frameborder="0"
      scrolling="no"
      loading="lazy"
    />
  </div>

  <p class="newsletter-alt">Prefer <a href="/rss.xml">RSS</a>? That works too.</p>
</aside>

<script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>

<style>
  .newsletter {
    margin: 2em 0;
    padding: 1.8em;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 7%, transparent), color-mix(in srgb, var(--accent) 15%, transparent));
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 24%, transparent);
  }

  .newsletter-header {
    text-align: center;
    margin-bottom: 1em;
  }

  .newsletter-header h3 {
    margin: 0;
    font-size: 1.15rem;
  }

  .newsletter-header p {
    margin: 0.45em 0 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .beehiiv-embed {
    max-width: 500px;
    margin: 0 auto;
  }

  .beehiiv-embed iframe {
    width: 100%;
    min-height: 240px;
    border: 0;
    border-radius: 10px;
    background: transparent;
  }

  .newsletter-alt {
    margin: 1em 0 0;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.88rem;
  }
</style>
